{
    "name": "agent-platform",
    "version": "1.0.0",
    "description": "Agent Platform with FastAPI backend and React frontend",
    "main": "index.js",
    "scripts": {
        "setup:venv": "python3 -m venv venv && ./venv/bin/pip install -r requirements.txt",
        "dev:backend": "./venv/bin/uvicorn main:app --reload --port 8001",
        "dev:frontend": "cd frontend && npm run dev",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "install:all": "npm install && npm run setup:venv && cd frontend && npm install",
        "start": "npm run dev"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}